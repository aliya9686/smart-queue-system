# ── Dependencies ──────────────────────────────────────────────
node_modules/
server/node_modules/
client/node_modules/

# ── Environment secrets ───────────────────────────────────────
server/.env
client/.env
.env

# ── Build artifacts ───────────────────────────────────────────
client/dist/
server/dist/

# ── TypeScript build info ─────────────────────────────────────
*.tsbuildinfo
client/vite.config.d.ts

# ── Prisma ────────────────────────────────────────────────────
